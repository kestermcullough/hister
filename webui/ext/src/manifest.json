{
  "manifest_version": 3,
  "name": "Hister",
  "version": "0.1.0",
  "description": "Web history on steroids",
  "icons": {
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "128": "assets/icons/icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Hister"
  },
  "commands": {
    "index-current-page": {
      "suggested_key": {
        "default": "Ctrl+I",
        "mac": "Command+I"
      },
      "description": "Index current page"
    },
    "disable-indexing-current-page": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      },
      "description": "Disable indexing for current page"
    },
    "disable-indexing-current-domain": {
      "suggested_key": {
        "default": "Ctrl+Y",
        "mac": "Command+Y"
      },
      "description": "Disable indexing for current domain"
    }
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {},
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": [],
      "extension_ids": []
    }
  ],
  "permissions": ["tabs", "storage", "cookies"],
  "host_permissions": ["*://*/*"],
  "key": ""
}
